// Profile all slow patterns (convs + encoder matmul/attention) standalone.
// Run from repo root:
//   PYTHONPATH=src python3 -m einlang tests/profile_single_statement.ein --profile-statements --profile-reductions
// Or per-function:
//   PYTHONPATH=src python3 -m einlang tests/profile_single_statement.ein --profile-functions
//
// Patterns: conv_c1 (384,3000), conv_c2 (384,1500), matmul_qkv, attn_score (6,1500,1500),
//           attn_ctx (6,1500,64), proj, fc1 (1500,1536), fc2 (1500,384).
// Heaviest: attn_score, attn_ctx, fc1, fc2 — may need substantial RAM for full run.

// --- Conv c1: sum[ci,k](mel_pad[ci, t+k] * W[co,ci,k]) + B  → (384, 3000) [was ~18s]
fn profile_conv_c1() -> [f32; 384, 3000] {
    let W[co in 0..384, ci in 0..80, k in 0..3] = 0.01;
    let B[co in 0..384] = 0.0;
    let X[c in 0..80, t in 0..3002] = if t >= 1 && t < 3001 { 1.0 } else { 0.0 };
    let Y[co in 0..384, t in 0..3000] =
        sum[ci in 0..80, k in 0..3](X[ci, t + k] * W[co, ci, k]) + B[co];
    Y
}

// --- Conv c2: sum[ci,k](c1_pad[ci, t*2+k] * W[co,ci,k]) + B  → (384, 1500) [was ~72s]
fn profile_conv_c2() -> [f32; 384, 1500] {
    let W[co in 0..384, ci in 0..384, k in 0..3] = 0.01;
    let B[co in 0..384] = 0.0;
    let X[c in 0..384, t in 0..3002] = if t >= 1 && t < 3001 { 1.0 } else { 0.0 };
    let Y[co in 0..384, t in 0..1500] =
        sum[ci in 0..384, k in 0..3](X[ci, t * 2 + k] * W[co, ci, k]) + B[co];
    Y
}

// --- Matmul Q/K/V: sum[k](ln1[s,k] * W[k,d]) + B  → (1500, 384)
fn profile_matmul_qkv() -> [f32; 1500, 384] {
    let W[k in 0..384, d in 0..384] = 0.01;
    let B[d in 0..384] = 0.0;
    let ln1[s in 0..1500, k in 0..384] = 0.1;
    let Q[s in 0..1500, d in 0..384] =
        sum[k in 0..384](ln1[s, k] * W[k, d]) + B[d];
    Q
}

// --- Attention score: sum[d](Qh[h,i,d] * Kh[h,j,d]) / 8.0  → (6, 1500, 1500)
fn profile_attn_score() -> [f32; 6, 1500, 1500] {
    let Qh[h in 0..6, i in 0..1500, d in 0..64] = 0.01;
    let Kh[h in 0..6, j in 0..1500, d in 0..64] = 0.01;
    let score[h in 0..6, i in 0..1500, j in 0..1500] =
        sum[d in 0..64](Qh[h, i, d] * Kh[h, j, d]) / 8.0;
    score
}

// --- Attention context: sum[j](attn[h,i,j] * Vh[h,j,d])  → (6, 1500, 64)
fn profile_attn_ctx() -> [f32; 6, 1500, 64] {
    let attn[h in 0..6, i in 0..1500, j in 0..1500] = 0.001;
    let Vh[h in 0..6, j in 0..1500, d in 0..64] = 0.01;
    let ctx[h in 0..6, i in 0..1500, d in 0..64] =
        sum[j in 0..1500](attn[h, i, j] * Vh[h, j, d]);
    ctx
}

// --- Proj: sum[k](cat[s,k] * W[k,d]) + B  → (1500, 384)
fn profile_proj() -> [f32; 1500, 384] {
    let W[k in 0..384, d in 0..384] = 0.01;
    let B[d in 0..384] = 0.0;
    let cat[s in 0..1500, k in 0..384] = 0.1;
    let proj[s in 0..1500, d in 0..384] =
        sum[k in 0..384](cat[s, k] * W[k, d]) + B[d];
    proj
}

// --- FC1: sum[d](ln2[s,d] * W[d,k]) + B  → (1500, 1536)
fn profile_fc1() -> [f32; 1500, 1536] {
    let W[d in 0..384, k in 0..1536] = 0.01;
    let B[k in 0..1536] = 0.0;
    let ln2[s in 0..1500, d in 0..384] = 0.1;
    let fc1[s in 0..1500, k in 0..1536] =
        sum[d in 0..384](ln2[s, d] * W[d, k]) + B[k];
    fc1
}

// --- FC2: sum[k](act[s,k] * W[k,d]) + B  → (1500, 384)
fn profile_fc2() -> [f32; 1500, 384] {
    let W[k in 0..1536, d in 0..384] = 0.01;
    let B[d in 0..384] = 0.0;
    let act[s in 0..1500, k in 0..1536] = 0.1;
    let fc2[s in 0..1500, d in 0..384] =
        sum[k in 0..1536](act[s, k] * W[k, d]) + B[d];
    fc2
}

// Run all patterns (each in its own function for clear profile lines)
let _ = profile_conv_c1();
let _ = profile_conv_c2();
let _ = profile_matmul_qkv();
let _ = profile_attn_score();
let _ = profile_attn_ctx();
let _ = profile_proj();
let _ = profile_fc1();
let _ = profile_fc2();
