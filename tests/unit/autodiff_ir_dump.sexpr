      "let A = [[1.0, 2.0], [3.0, 4.0]];
let B = [[5.0, 6.0], [7.0, 8.0]];
let C[i, j] = sum[k](A[i, k] * B[k, j]);
let dC_dA = @C / @A;
let M = [[1.0, 2.0], [3.0, 4.0]];
let r[i] = sum[j](M[i, j]);
let dr_dM = @r / @M;
let x = [[1.0, 2.0], [3.0, 4.0]];
let W = [[0.5, 0.5], [0.1, 0.2]];
let b = [0.1, 0.2];
let y[i, j] = sum[k](x[i, k] * W[j, k]) + b[j];
let dy_dx = @y / @x;"
    )
  )
)