  :source_files
  (("<test>"
      "let scale = 0.5;
let Q = [[[1.0, 2.0], [3.0, 4.0]]];
let K = [[[1.0, 2.0], [3.0, 4.0]]];
let V = [[[1.0, 0.0], [0.0, 1.0]]];
let scores[b, i, j] = sum[d](Q[b, i, d] * K[b, j, d]) * scale;
let out[b, i, d] = sum[j](scores[b, i, j] * V[b, j, d]);
let d_out_d_Q = @out / @Q;"
    )
