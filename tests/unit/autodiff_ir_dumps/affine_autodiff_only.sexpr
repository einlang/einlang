  (("<test>"
      "let x = [[1.0, 2.0], [3.0, 4.0]];
let W = [[0.5, 0.5], [0.1, 0.2]];
let b = [0.1, 0.2];
let y[i, j] = sum[k](x[i, k] * W[j, k]) + b[j];
let dy_dx = @y / @x;
let dy_dW = @y / @W;
let dy_db = @y / @b;"
    )
