// Softmax: softmax(x)_i = exp(x_i) / sum_j(exp(x_j)). No recurrence; reductions + exp.
//
// Julia equivalent (1-based; same order as below):
//   x = [1.0, 2.0, 3.0, 1.0, 0.5]
//   exp_x = exp.(x)
//   Z = sum(exp_x)
//   softmax = exp_x ./ Z

use std::math::exp::exp;

let x = [1.0, 2.0, 3.0, 1.0, 0.5];
let exp_x = exp(x);
let Z = sum[i](exp_x[i]);
let softmax = exp_x / Z;

print(softmax);
