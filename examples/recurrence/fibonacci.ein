// Fibonacci: fib[0]=0, fib[1]=1, fib[n] = fib[n-1] + fib[n-2]
// Classic recurrence; compiler handles evaluation order.
//
// Julia equivalent (1-based; same order as below):
//   fib = zeros(Int, 25)
//   fib[1] = 0
//   fib[2] = 1
//   for n in 3:25
//       fib[n] = fib[n-1] + fib[n-2]
//   end

let fib[0] = 0;
let fib[1] = 1;
let fib[n in 2..25] = fib[n - 1] + fib[n - 2];

print(fib);
