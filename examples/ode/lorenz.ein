// Lorenz system: dx/dt = œÉ(y‚àíx), dy/dt = x(œÅ‚àíz)‚àíy, dz/dt = xy‚àíŒ≤z
// Euler: u[t,0]=x, u[t,1]=y, u[t,2]=z. Julia: DifferentialEquations.jl
//
// Julia equivalent (1-based; same order as below):
//   sigma = 10.0
//   rho = 28.0
//   beta = 2.666666666666667
//   dt = 0.01
//   x0 = 1.0
//   y0 = 1.0
//   z0 = 1.0
//   u = zeros(2000, 3)
//   u[1, 1] = x0
//   u[1, 2] = y0
//   u[1, 3] = z0
//   for t in 2:2000
//       u[t, 1] = u[t-1, 1] + dt * (sigma * (u[t-1, 2] - u[t-1, 1]))
//       u[t, 2] = u[t-1, 2] + dt * (u[t-1, 1] * (rho - u[t-1, 3]) - u[t-1, 2])
//       u[t, 3] = u[t-1, 3] + dt * (u[t-1, 1] * u[t-1, 2] - beta * u[t-1, 3])
//   end

let sigma = 10.0;
let rho = 28.0;
let beta = 2.666666666666667;
let dt = 0.01;
let x0 = 1.0;
let y0 = 1.0;
let z0 = 1.0;

let u[0, 0] = x0;
let u[0, 1] = y0;
let u[0, 2] = z0;

let u[t in 1..2000, 0] = u[t - 1, 0] + dt * (sigma * (u[t - 1, 1] - u[t - 1, 0]));
let u[t in 1..2000, 1] = u[t - 1, 1] + dt * (u[t - 1, 0] * (rho - u[t - 1, 2]) - u[t - 1, 1]);
let u[t in 1..2000, 2] = u[t - 1, 2] + dt * (u[t - 1, 0] * u[t - 1, 1] - beta * u[t - 1, 2]);
